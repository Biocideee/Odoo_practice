<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="action_hospital_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hr_hospital.doctor</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_hospital_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hr_hospital.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_hospital_root" name="Hospital" sequence="10"/>

    <menuitem id="menu_hospital_doctor"
              name="Doctors"
              parent="menu_hr_hospital_root"
              action="action_hospital_doctor"
              sequence="10"/>

    <menuitem id="menu_hospital_patient"
              name="Patients"
              parent="menu_hr_hospital_root"
              action="action_hospital_patient"
              sequence="20"/>
</odoo>
