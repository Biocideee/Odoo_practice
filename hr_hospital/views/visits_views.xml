<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- СПИСОК -->

    <record id="view_visits_list" model="ir.ui.view">
        <field name="name">hr.hospital.patient.visits.list</field>
        <field name="model">hr_hospital.patient_visits</field>
        <field name="arch" type="xml">
            <list string="All Visits"
                  decoration-info="visit_status == 'scheduled'"
                  decoration-success="visit_status == 'completed'"
                  decoration-muted="visit_status == 'cancelled'">

                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="planned_date_and_time"/>
                <field name="visit_status" widget="badge"
                       decoration-info="visit_status == 'scheduled'"
                       decoration-success="visit_status == 'completed'"/>
            </list>
        </field>
    </record>

    <!-- ФОРМА -->

    <record id="view_visits_form" model="ir.ui.view">
        <field name="name">hr.hospital.patient.visits.form</field>
        <field name="model">hr_hospital.patient_visits</field>
        <field name="arch" type="xml">
            <form string="Patient's visit">

                <header>
                    <field name="visit_status"
                           widget="statusbar"
                           options="{'clickable' : '1'}"
                           statusbar_visible="scheduled,completed"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="doctor_id"/>
                            <field name="type_of_visit"/>
                        </group>

                        <group>
                            <field name="planned_date_and_time"/>
                            <field name="actual_date_and_time"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Diagnoses">
                            <field name="diagnosis_ids">
                                <list editable="bottom">
                                    <field name="disease_id"/>
                                </list>
                            </field>
                        </page>

                        <page string="Recommendations">
                            <field name="recommendations"/>
                        </page>

                        <page string="Financial">
                            <group>
                                <field name="value_of_visit"/>
                                <field name="currency_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- КАЛЕНДАР -->

    <record id="view_visits_calendar" model="ir.ui.view">
        <field name="name">hr.hospital.patient.visits.calendar</field>
        <field name="model">hr_hospital.patient_visits</field>
        <field name="arch" type="xml">
            <calendar string="Patient Visits"
                      date_start="planned_date_and_time"
                      date_stop="actual_date_and_time"
                      color="doctor_id"
                      mode="week">
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="visit_status"/>
            </calendar>
        </field>
    </record>

    <!-- ПОШУК -->
    <record id="view_visits_search" model="ir.ui.view">
        <field name="name">hr.hospital.patient.visits.search</field>
        <field name="model">hr_hospital.patient_visits</field>
        <field name="arch" type="xml">
            <search string="Search Visits">
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="name"/>
                <filter string="Current Month"
                        name="filter_current_month"
                        domain="[
                            ('planned_date_and_time', '&gt;=', context_today().strftime('%Y-%m-01')),
                            ('planned_date_and_time', '&lt;', (context_today() + relativedelta(months=1)).strftime('%Y-%m-01'))
                        ]"/>

                <group>
                    <filter string="Status" name="group_by_status" context="{'group_by' : 'visit_status'}"/>
                    <filter string="Doctor" name="group_by_doctor" context="{'group_by' : 'doctor_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ЗВЕДЕНА ТАБЛИЦЯ -->

    <record id="view_visits_pivot" model="ir.ui.view">
        <field name="name">hr.hospital.patient.visits.pivot</field>
        <field name="model">hr_hospital.patient_visits</field>
        <field name="arch" type="xml">
            <pivot string="Visits Pivot">
                <field name="doctor_id" type="row"/>
                <field name="visit_status" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- ДІЯ -->

    <record id="action_visits" model="ir.actions.act_window">
        <field name="name">Visits</field>
        <field name="res_model">hr_hospital.patient_visits</field>
        <field name="view_mode">list,calendar,pivot,form</field>
        <field name="context">{'search_default_filter_current_month': 1}</field>
    </record>
</odoo>