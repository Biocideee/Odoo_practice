<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_move_form_inherit_correction" model="ir.ui.view">
        <field name="name">account.move.form.inherit.correction</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_correction"
                        string="Скорегувати"
                        type="object"
                        invisible="state == 'draft'"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='quantity']" position="attributes">
                <attribute name="readonly">is_storno</attribute>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_unit']" position="attributes">
                <attribute name="readonly">is_storno</attribute>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='name']" position="after">
                <field name="is_storno" column_invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>